# ===========================================
# Assistant de Direction — Variables d'environnement
# ===========================================
# Copier ce fichier en .env et remplir les valeurs.
# Le fichier .env ne doit JAMAIS être commité.

# --- LLM (Groq) ---
# Obtenir une cle gratuite sur https://console.groq.com/keys
GROQ_API_KEY=

# Modele LLM a utiliser (doit supporter le tool calling)
GROQ_MODEL=llama-3.3-70b-versatile

# --- Base de donnees ---
# Chemin SQLite (relatif a la racine du projet ou au WORKDIR Docker)
DATABASE_URL=sqlite:///./data/assistant.db

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Logging ---
LOG_LEVEL=INFO
